---Audit table
--Audit/history table:
 CREATE TABLE PayRateAudit (
    AuditID INT PRIMARY KEY IDENTITY(1,1),
    EmployeeID INT NOT NULL,
    OldRate DECIMAL(10,2),
    NewRate DECIMAL(10,2),
    ChangeDate DATETIME DEFAULT GETDATE()
);

------
---Queries for reporting/demo
---Select all employees

SELECT * FROM Employees;

-----
---join query
SELECT 
    e.EmployeeID,
    e.FirstName,
    e.LastName,
    p.WeekStartDate,
    p.GrossPay
FROM Payroll p
JOIN Employees e
    ON p.EmployeeID = e.EmployeeID;

---filter query
--used for overtime employees
SELECT *
FROM HoursWorked
WHERE HoursWorked > 40;

----
---Aggregate query
---used for total payroll
SELECT 
    WeekStartDate,
    SUM(GrossPay) AS TotalWeeklyPayroll
FROM Payroll
GROUP BY WeekStartDate;
-----
---order results
ORDER BY ChangeDate DESC;

